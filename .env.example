# ── Supabase ──
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ── Gemini AI (Lead Hunter cold emails / fit scores) ──
# Get a free key at https://ai.google.dev
# Vite bundles env vars into the client JS, so the key will be visible in the
# built APK. For an internal CRM this is an accepted tradeoff.
VITE_GEMINI_API_KEY=your-gemini-api-key

# ── OLA Maps (Krutrim Cloud) ──
# Sign up at https://maps.olakrutrim.com/dashboard → Credentials
# Free tier: 5 million API calls/month
VITE_OLA_MAPS_API_KEY=your-ola-maps-api-key
